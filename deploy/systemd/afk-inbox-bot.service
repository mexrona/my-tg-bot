[Unit]
Description=AFK Inbox Telegram Bot (my-tg-bot)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=__DEPLOY_USER__
Group=__DEPLOY_USER__
WorkingDirectory=__APP_DIR__
EnvironmentFile=__APP_DIR__/.env
ExecStart=__APP_DIR__/.venv/bin/python -m bot.main
Restart=on-failure
RestartSec=5

# Логи: journalctl -u afk-inbox-bot -f
StandardOutput=journal
StandardError=journal
SyslogIdentifier=afk-inbox-bot

[Install]
WantedBy=multi-user.target
